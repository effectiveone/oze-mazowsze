---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Layout title="OZE Mazowsze — Regionalny portal energetyczny">
  <div style="background:linear-gradient(180deg,var(--blue-dark) 0%,var(--blue-primary) 100%);color:#fff;padding:4rem 0 3rem;">
    <div class="container">
      <p style="font-size:0.8rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--blue-light);margin-bottom:0.5rem;">Regionalny portal OZE</p>
      <h1 style="font-size:clamp(2rem,5vw,3.2rem);font-weight:700;margin-bottom:1rem;color:#fff;">Odnawialne źródła energii<br/>na Mazowszu</h1>
      <p style="font-size:1.05rem;color:rgba(255,255,255,0.85);max-width:580px;margin-bottom:1.5rem;">Aktualne informacje o inwestycjach OZE, polityce energetycznej i zielonej transformacji regionu mazowieckiego.</p>
      <a href="/blog" style="background:#fff;color:var(--blue-dark);padding:0.65rem 1.5rem;font-weight:700;border-radius:3px;display:inline-block;font-size:0.9rem;">Aktualności OZE →</a>
    </div>
  </div>
  <div class="container" style="padding:2.5rem 1.5rem 3rem;">
    <div style="display:grid;grid-template-columns:1fr 280px;gap:3rem;" class="home-grid">
      <div>
        {posts.length > 0 ? (
          <>
            <h2 style="font-size:1.1rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);border-bottom:3px solid var(--blue-primary);padding-bottom:0.5rem;margin-bottom:1.5rem;">Najnowsze aktualności</h2>
            <div style="display:flex;flex-direction:column;gap:1rem;">
              {posts.slice(0,6).map(p => <PostCard title={p.data.title} description={p.data.description} slug={p.slug} pubDate={p.data.pubDate} tags={p.data.tags} />)}
            </div>
            {posts.length > 6 && <div style="margin-top:1.5rem;"><a href="/blog" style="background:var(--blue-pale);color:var(--blue-dark);padding:0.6rem 1.25rem;font-weight:700;font-size:0.88rem;border:1px solid var(--blue-light);">Wszystkie aktualności ({posts.length})</a></div>}
          </>
        ) : (
          <div style="padding:3rem 0;text-align:center;color:var(--text-muted);">
            <p style="font-size:1.1rem;">Aktualności pojawią się wkrótce.</p>
          </div>
        )}
      </div>
      <aside>
        <div style="background:var(--blue-pale);border:1px solid var(--border);padding:1.5rem;">
          <h3 style="font-size:0.85rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);border-bottom:2px solid var(--blue-primary);padding-bottom:0.4rem;margin-bottom:1rem;">O portalu</h3>
          <p style="font-size:0.88rem;color:var(--text-muted);line-height:1.6;margin-bottom:1rem;">Portal gromadzi informacje o transformacji energetycznej Mazowsza — regionu z rosnącym potencjałem OZE.</p>
          <a href="https://ecoaudyt.app" target="_blank" style="display:block;background:var(--blue-primary);color:#fff;text-align:center;padding:0.6rem;font-weight:700;font-size:0.88rem;border-radius:3px;">🔋 Audyt energetyczny</a>
        </div>
      </aside>
    </div>
  </div>
</Layout>
<style>
@media (max-width:768px) { .home-grid { grid-template-columns:1fr !important; } }
</style>
