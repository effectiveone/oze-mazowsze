---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Layout title="Aktualności — OZE Mazowsze">
  <div class="container" style="padding:2.5rem 1.5rem 3rem;">
    <h1 style="color:var(--blue-dark);font-size:2rem;border-bottom:3px solid var(--blue-primary);padding-bottom:0.5rem;margin-bottom:0.75rem;">Aktualności OZE</h1>
    <p style="color:var(--text-muted);margin-bottom:2rem;">{posts.length} artykułów w bazie</p>
    {posts.length > 0 ? (
      <div style="display:flex;flex-direction:column;gap:1rem;">
        {posts.map(p => <PostCard title={p.data.title} description={p.data.description} slug={p.slug} pubDate={p.data.pubDate} tags={p.data.tags} />)}
      </div>
    ) : <p style="text-align:center;color:var(--text-muted);padding:3rem 0;">Artykuły pojawią się wkrótce.</p>}
  </div>
</Layout>
